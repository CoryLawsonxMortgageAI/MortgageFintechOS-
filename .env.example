# MortgageFintechOS Configuration
# ================================

# --- Infrastructure ---
DATABASE_URL=postgresql://user:password@localhost:5432/mortgageos
REDIS_URL=redis://localhost:6379

# --- GitHub Integration ---
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=CoryLawsonxMortgageAI/MortgageFintechOS-
WEBHOOK_SECRET=your_webhook_secret_here

# --- System ---
LOG_LEVEL=INFO
AGENT_RETRY_COUNT=3
AGENT_HEARTBEAT_INTERVAL=30
ENCRYPTION_KEY=your-256-bit-key-here
DATA_DIR=data

# --- Dashboard ---
DASHBOARD_PORT=8080
DASHBOARD_HOST=0.0.0.0

# --- Notifications ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/DISCORD/WEBHOOK

# --- LLM Integration (Free Models) ---
# Primary: Groq — Free, fastest inference (Llama 3.3 70B)
# Get key at: https://console.groq.com
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Secondary: Google Gemini — Free tier (Gemini 2.0 Flash)
# Get key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.0-flash

# Tertiary: Together AI — Free credits on signup (Llama 3.1 70B)
# Get key at: https://api.together.xyz
TOGETHER_API_KEY=your_together_key_here
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo

# --- Telegram Bot ---
# Message @BotFather on Telegram → /newbot → get token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret_here

# --- X.com (Twitter) ---
# Create app at https://developer.x.com
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_SECRET=your_x_access_secret_here

# --- Railway/Render/Fly.io (auto-set by platform) ---
# PORT=8080
