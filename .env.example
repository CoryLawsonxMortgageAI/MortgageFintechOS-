# MortgageFintechOS Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/mortgageos
REDIS_URL=redis://localhost:6379
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=CoryLawsonxMortgageAI/MortgageFintechOS-
LOG_LEVEL=INFO
AGENT_RETRY_COUNT=3
AGENT_HEARTBEAT_INTERVAL=30
ENCRYPTION_KEY=your-256-bit-key-here
DASHBOARD_PORT=8080
DASHBOARD_HOST=0.0.0.0
DATA_DIR=data

# Notion (API v2025-09-03)
NOTION_API_TOKEN=secret_your_integration_token_here
NOTION_DATABASE_ID=your_database_id_here
NOTION_DATA_SOURCE_ID=your_data_source_id_here

# Wispr Flow
WISPR_WEBHOOK_SECRET=your_wispr_webhook_secret_here

# Google Drive
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json

# LLM Router (multi-model agentic intelligence)
OPENAI_API_KEY=sk-your_openai_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here
DEFAULT_LLM_PROVIDER=openrouter
DEFAULT_LLM_MODEL=anthropic/claude-sonnet-4-6

# GHOST OSINT CRM (entity investigation + borrower verification)
GHOST_BASE_URL=http://localhost:5000
GHOST_API_KEY=your_ghost_api_key_here

# PentAGI (autonomous penetration testing)
PENTAGI_BASE_URL=http://localhost:8443
